# CivicOps Agent environment template
# Copy to .env for Docker Compose or backend/.env for local backend development.

APP_NAME=CivicOps Agent
APP_VERSION=1.0.0
ENVIRONMENT=local

# Docker Compose uses the db hostname inside the Docker network.
DATABASE_URL=postgresql+psycopg://civicops:civicops@db:5432/civicops

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Optional. Leave mock for no-key demos.
LLM_PROVIDER=mock
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
