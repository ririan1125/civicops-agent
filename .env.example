# CivicOps Agent environment template
# Copy to .env for Docker Compose or backend/.env for local backend development.

APP_NAME=CivicOps Agent
APP_VERSION=1.0.0
ENVIRONMENT=local

# Docker Compose uses the db hostname inside the Docker network.
DATABASE_URL=postgresql+psycopg://civicops:civicops@db:5432/civicops

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Optional. Leave mock for no-key demos.
LLM_PROVIDER=mock
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# RAG embeddings. local_hash keeps the demo reproducible without an API key.
# Set EMBEDDING_PROVIDER=api plus an OpenAI-compatible embedding endpoint for production-like semantic retrieval.
EMBEDDING_PROVIDER=local_hash
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=384

# RAG source refresh. Set true when you want automatic empty-index rebuilds to fetch official remote sources.
RAG_INCLUDE_REMOTE_SOURCES=false
RAG_REMOTE_TIMEOUT_SECONDS=35

# Incremental NYC 311 sync defaults.
INGESTION_SYNC_LIMIT=5000
INGESTION_SYNC_LOOKBACK_DAYS=7
